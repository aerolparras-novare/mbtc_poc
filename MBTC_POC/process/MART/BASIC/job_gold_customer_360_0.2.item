    <nodeData xsi:type="TalendDBMap:DBMapData">
      <InputTables name="silver.customers" tableName="silver.customers" joinType="JOIN">
        <DBMapperTableEntries name="CUSTOMER_ID"/>
        <DBMapperTableEntries name="FIRST_NAME"/>
        <DBMapperTableEntries name="LAST_NAME"/>
        <DBMapperTableEntries name="EMAIL"/>
        <DBMapperTableEntries name="JOIN_DATE"/>
        <DBMapperTableEntries name="KYC_STATUS"/>
      </InputTables>
      <InputTables name="gold.customer_360_cte1" tableName="gold.customer_360_cte1" joinType="LEFT_OUTER_JOIN">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.customers.CUSTOMER_ID " join="true" operator="="/>
        <DBMapperTableEntries name="TOTAL_ACCOUNTS"/>
        <DBMapperTableEntries name="SAVINGS_BALANCE"/>
        <DBMapperTableEntries name="CHECKING_BALANCE"/>
        <DBMapperTableEntries name="CC_BALANCE"/>
        <DBMapperTableEntries name="TOTAL_RELATIONSHIP_BALANCE"/>
      </InputTables>
      <InputTables name="gold.customer_360_cte2" tableName="gold.customer_360_cte2" joinType="LEFT_OUTER_JOIN">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.customers.CUSTOMER_ID " join="true" operator="="/>
        <DBMapperTableEntries name="TOTAL_TXN_COUNT"/>
        <DBMapperTableEntries name="TOTAL_DEPOSITS_LIFETIME"/>
        <DBMapperTableEntries name="TOTAL_WITHDRAWALS_LIFETIME"/>
        <DBMapperTableEntries name="LAST_TXN_DATE"/>
      </InputTables>
      <OutputTables name="table3" tableName="customer_360">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.customers.CUSTOMER_ID"/>
        <DBMapperTableEntries name="FULL_NAME" expression="concat(silver.customers.FIRST_NAME, ' ', silver.customers.LAST_NAME) "/>
        <DBMapperTableEntries name="EMAIL" expression="silver.customers.EMAIL"/>
        <DBMapperTableEntries name="KYC_STATUS" expression="silver.customers.KYC_STATUS"/>
        <DBMapperTableEntries name="TENURE_DAYS" expression="datediff(current_date(), to_date(silver.customers.JOIN_DATE)) "/>
        <DBMapperTableEntries name="TOTAL_ACCOUNTS" expression="COALESCE(gold.customer_360_cte1.TOTAL_ACCOUNTS, 0) "/>
        <DBMapperTableEntries name="SAVINGS_BALANCE" expression="COALESCE(gold.customer_360_cte1.SAVINGS_BALANCE,0) "/>
        <DBMapperTableEntries name="CHECKING_BALANCE" expression="COALESCE(gold.customer_360_cte1.CHECKING_BALANCE,0) "/>
        <DBMapperTableEntries name="CREDIT_CARD_EXPOSURE" expression="COALESCE(gold.customer_360_cte1.TOTAL_RELATIONSHIP_BALANCE, 0) "/>
        <DBMapperTableEntries name="TOTAL_BALANCE" expression="COALESCE(gold.customer_360_cte1.TOTAL_RELATIONSHIP_BALANCE, 0) "/>
        <DBMapperTableEntries name="LIFETIME_TXN_COUNT" expression="COALESCE(gold.customer_360_cte2.TOTAL_TXN_COUNT,0) "/>
        <DBMapperTableEntries name="TOTAL_DEPOSITS" expression="COALESCE(gold.customer_360_cte2.TOTAL_DEPOSITS_LIFETIME, 0) "/>
        <DBMapperTableEntries name="TOTAL_WITHDRAWALS" expression="COALESCE(gold.customer_360_cte2.TOTAL_WITHDRAWALS_LIFETIME, 0) "/>
        <DBMapperTableEntries name="LAST_TXN_DATE" expression="gold.customer_360_cte2.LAST_TXN_DATE"/>
        <DBMapperTableEntries name="CUSTOMER_LIFECYCLE_STATUS" expression="CASE &#xD;&#xA;&#x9;WHEN gold.customer_360_cte2.LAST_TXN_DATE >= date_sub(current_date(), 30) THEN 'Active'&#xD;&#xA;&#x9;WHEN gold.customer_360_cte2.LAST_TXN_DATE IS NULL THEN 'No Activity'&#xD;&#xA;&#x9;ELSE 'Dormant'&#xD;&#xA;END "/>
      </OutputTables>
    </nodeData>
  </node>
