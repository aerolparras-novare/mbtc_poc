    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;CREATE TABLE IF NOT EXISTS gold.customer_360_cte1 (&#xD;&#xA;    customer_id                 BIGINT COMMENT 'Linked to silver.customers',&#xD;&#xA;    total_accounts              BIGINT,&#xD;&#xA;    savings_balance             DECIMAL(18,2),&#xD;&#xA;    checking_balance            DECIMAL(18,2),&#xD;&#xA;    cc_balance                  DECIMAL(18,2),&#xD;&#xA;    total_relationship_balance  DECIMAL(18,2)&#xD;&#xA;)&#xD;&#xA;STORED AS ORC&#xD;&#xA;-- CRITICAL CHANGE 2: Enable ACID transactions&#xD;&#xA;TBLPROPERTIES ('transactional'='true')&#xD;&#xA;&quot;"/>
