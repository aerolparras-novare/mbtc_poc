    <nodeData xsi:type="TalendDBMap:DBMapData">
      <InputTables name="silver.customers" tableName="silver.customers" joinType="JOIN">
        <DBMapperTableEntries name="CUSTOMER_ID"/>
        <DBMapperTableEntries name="FIRST_NAME"/>
        <DBMapperTableEntries name="LAST_NAME"/>
        <DBMapperTableEntries name="EMAIL"/>
        <DBMapperTableEntries name="JOIN_DATE"/>
        <DBMapperTableEntries name="KYC_STATUS"/>
      </InputTables>
      <InputTables name="silver.stage_account_summary" tableName="silver.stage_account_summary" joinType="LEFT_OUTER_JOIN">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.customers.CUSTOMER_ID " join="true" operator="="/>
        <DBMapperTableEntries name="TOTAL_ACCOUNTS"/>
        <DBMapperTableEntries name="SAVINGS_BALANCE"/>
        <DBMapperTableEntries name="CHECKING_BALANCE"/>
        <DBMapperTableEntries name="CC_BALANCE"/>
        <DBMapperTableEntries name="TOTAL_RELATIONSHIP_BALANCE"/>
      </InputTables>
      <InputTables name="silver.stage_txn_summary" tableName="silver.stage_txn_summary" joinType="LEFT_OUTER_JOIN">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.customers.CUSTOMER_ID " join="true" operator="="/>
        <DBMapperTableEntries name="TOTAL_TXN_COUNT"/>
        <DBMapperTableEntries name="TOTAL_DEPOSITS_LIFETIME"/>
        <DBMapperTableEntries name="TOTAL_WITHDRAWALS_LIFETIME"/>
        <DBMapperTableEntries name="LAST_TXN_DATE"/>
      </InputTables>
      <OutputTables name="table3" tableName="customer_360">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.customers.CUSTOMER_ID"/>
        <DBMapperTableEntries name="FULL_NAME" expression="concat(silver.customers.FIRST_NAME, ' ', silver.customers.LAST_NAME) "/>
        <DBMapperTableEntries name="EMAIL" expression="silver.customers.EMAIL"/>
        <DBMapperTableEntries name="KYC_STATUS" expression="silver.customers.KYC_STATUS"/>
        <DBMapperTableEntries name="TENURE_DAYS" expression="datediff(current_date(), to_date(silver.customers.JOIN_DATE)) "/>
        <DBMapperTableEntries name="TOTAL_ACCOUNTS" expression="COALESCE(silver.stage_account_summary.TOTAL_ACCOUNTS, 0) "/>
        <DBMapperTableEntries name="SAVINGS_BALANCE" expression="COALESCE(silver.stage_account_summary.SAVINGS_BALANCE,0) "/>
        <DBMapperTableEntries name="CHECKING_BALANCE" expression="COALESCE(silver.stage_account_summary.CHECKING_BALANCE,0) "/>
        <DBMapperTableEntries name="CREDIT_CARD_EXPOSURE" expression="COALESCE(silver.stage_account_summary.CC_BALANCE,0) "/>
        <DBMapperTableEntries name="TOTAL_BALANCE" expression="COALESCE(silver.stage_account_summary.TOTAL_RELATIONSHIP_BALANCE, 0) "/>
        <DBMapperTableEntries name="LIFETIME_TXN_COUNT" expression="COALESCE(silver.stage_txn_summary.TOTAL_TXN_COUNT,0) "/>
        <DBMapperTableEntries name="TOTAL_DEPOSITS" expression="COALESCE(silver.stage_txn_summary.TOTAL_DEPOSITS_LIFETIME, 0) "/>
        <DBMapperTableEntries name="TOTAL_WITHDRAWALS" expression="COALESCE(silver.stage_txn_summary.TOTAL_WITHDRAWALS_LIFETIME, 0) "/>
        <DBMapperTableEntries name="LAST_TXN_DATE" expression="silver.stage_txn_summary.LAST_TXN_DATE"/>
        <DBMapperTableEntries name="CUSTOMER_LIFECYCLE_STATUS" expression="CASE &#xD;&#xA;&#x9;WHEN silver.stage_txn_summary.LAST_TXN_DATE >= date_sub(current_date(), 30) THEN 'Active'&#xD;&#xA;&#x9;WHEN silver.stage_txn_summary.LAST_TXN_DATE IS NULL THEN 'No Activity'&#xD;&#xA;&#x9;ELSE 'Dormant'&#xD;&#xA;END "/>
      </OutputTables>
    </nodeData>
  </node>
