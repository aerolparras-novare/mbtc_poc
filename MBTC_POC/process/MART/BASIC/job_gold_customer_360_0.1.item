    <nodeData xsi:type="TalendDBMap:DBMapData">
      <InputTables name="silver.transactions" tableName="silver.transactions" joinType="JOIN">
        <DBMapperTableEntries name="TRANSACTION_ID"/>
        <DBMapperTableEntries name="ACCOUNT_ID"/>
        <DBMapperTableEntries name="TXN_TYPE"/>
        <DBMapperTableEntries name="AMOUNT"/>
        <DBMapperTableEntries name="TXN_DATE"/>
        <DBMapperTableEntries name="MERCHANT"/>
        <DBMapperTableEntries name="STATUS"/>
      </InputTables>
      <InputTables name="silver.accounts" tableName="silver.accounts" joinType="JOIN">
        <DBMapperTableEntries name="ACCOUNT_ID" expression="silver.transactions.ACCOUNT_ID " join="true" operator="="/>
        <DBMapperTableEntries name="CUSTOMER_ID" expression="" operator=""/>
      </InputTables>
      <OutputTables name="table5" tableName="stage_txn_summary">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.accounts.CUSTOMER_ID "/>
        <DBMapperTableEntries name="TOTAL_TXN_COUNT" expression="COUNT(silver.transactions.TRANSACTION_ID) AS TOTAL_TXN_COUNT "/>
        <DBMapperTableEntries name="TOTAL_DEPOSITS_LIFETIME" expression="SUM(CASE WHEN silver.transactions.TXN_TYPE = 'Deposit' AND silver.transactions.STATUS = 'Posted' THEN silver.transactions.AMOUNT ELSE 0 END) AS TOTAL_DEPOSITS_LIFETIME "/>
        <DBMapperTableEntries name="TOTAL_WITHDRAWALS_LIFETIME" expression="SUM(CASE WHEN silver.transactions.TXN_TYPE = 'Withdrawal' AND silver.transactions.STATUS = 'Posted' THEN silver.transactions.AMOUNT ELSE 0 END) AS TOTAL_WITHDRAWALS_LIFETIME "/>
        <DBMapperTableEntries name="LAST_TXN_DATE" expression="MAX(silver.transactions.TXN_DATE) AS LAST_TXN_DATE "/>
        <FilterEntries name="newFilter4" expression="GROUP BY silver.accounts.CUSTOMER_ID " filterKind="OTHER_FILTER"/>
      </OutputTables>
    </nodeData>
  </node>
