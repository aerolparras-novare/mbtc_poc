    <nodeData xsi:type="TalendDBMap:DBMapData">
      <InputTables name="silver.accounts" tableName="silver.accounts" joinType="JOIN">
        <DBMapperTableEntries name="ACCOUNT_ID"/>
        <DBMapperTableEntries name="CUSTOMER_ID" expression="" operator=""/>
        <DBMapperTableEntries name="ACCOUNT_TYPE"/>
        <DBMapperTableEntries name="CURRENCY"/>
        <DBMapperTableEntries name="CURRENT_BALANCE"/>
        <DBMapperTableEntries name="CREATED_AT"/>
      </InputTables>
      <OutputTables name="table4" tableName="stage_account_summary">
        <DBMapperTableEntries name="CUSTOMER_ID" expression="silver.accounts.CUSTOMER_ID "/>
        <DBMapperTableEntries name="TOTAL_ACCOUNTS" expression="COUNT(silver.accounts.ACCOUNT_ID)"/>
        <DBMapperTableEntries name="SAVINGS_BALANCE" expression="SUM(CASE WHEN silver.accounts.ACCOUNT_TYPE = 'Savings' THEN silver.accounts.CURRENT_BALANCE ELSE 0 END) AS SAVINGS_BALANCE "/>
        <DBMapperTableEntries name="CHECKING_BALANCE" expression="SUM(CASE WHEN silver.accounts.ACCOUNT_TYPE = 'Checking' THEN silver.accounts.CURRENT_BALANCE ELSE 0 END) AS CHECKING_BALANCE "/>
        <DBMapperTableEntries name="CC_BALANCE" expression="SUM(CASE WHEN silver.accounts.ACCOUNT_TYPE = 'Credit Card' THEN silver.accounts.CURRENT_BALANCE ELSE 0 END) AS CC_BALANCE "/>
        <DBMapperTableEntries name="TOTAL_RELATIONSHIP_BALANCE" expression="SUM(silver.accounts.CURRENT_BALANCE) AS TOTAL_RELATIONSHIP_BALANCE "/>
        <FilterEntries name="newFilter3" expression="GROUP BY silver.accounts.CUSTOMER_ID " filterKind="OTHER_FILTER"/>
      </OutputTables>
    </nodeData>
  </node>
