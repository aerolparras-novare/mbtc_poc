        <mapperTableEntries name="LAST_TXN_DATE" expression="row8.last_txn_date" type="id_Date" nullable="true"/>
        <mapperTableEntries name="CUSTOMER_LIFECYCLE_STATUS" expression="(row8.last_txn_date != null &amp;&amp; &#xD;&#xA;&#x9;&#x9;&#x9;&#x9; TalendDate.diffDate(TalendDate.getCurrentDate(), row8.last_txn_date, &quot;dd&quot;) &lt;= 30) &#xD;&#xA;&#x9;&#x9;&#x9;&#x9; ? &quot;Active&quot; : &#xD;&#xA;&#x9;&#x9;&#x9;&#x9; (row8.last_txn_date == null ? &quot;No Activity&quot; : &quot;Dormant&quot;) " type="id_String" nullable="true"/>
      </outputTables>
