  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="360" posY="400" sizeX="120" sizeY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="context.event_start = TalendDate.getCurrentDate();&#xD;&#xA;context.event_start_str = TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;,context.event_start).toString();&#xD;&#xA;context.ingest_date = TalendDate.formatDate(&quot;yyyyMMdd&quot;,context.event_start);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;context.sqoop_location = context.dir_hdfs_bronze + context.tablename + &quot;/&quot; + context.partition_column +&quot;=&quot; + context.ingest_date + &quot;/&quot;;&#xD;&#xA;System.out.println(&quot;Sqoop Location: &quot; + context.sqoop_location);&#xD;&#xA;&#xD;&#xA;globalMap.put(&quot;job_user&quot;, System.getProperty(&quot;user.name&quot;));&#xD;&#xA;System.out.println(&quot;\n------------------------------------------------------------------------&quot;);&#xD;&#xA;System.out.println(&quot; &quot;);&#xD;&#xA;System.out.println(&quot;Start of Main Job&quot;);&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="startJob"/>
