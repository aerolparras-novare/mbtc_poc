    <elementParameter field="CHECK" name="USE_PARQUET" value="false"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;WITH source&#xD;&#xA;AS ( &#xD;&#xA;&#x9;SELECT &#xD;&#xA;        CAST(transaction_id AS INT) AS transaction_id,&#xD;&#xA; &#x9;&#x9;CAST(account_id AS INT) AS account_id,&#xD;&#xA;        txn_type, &#xD;&#xA;        CAST(amount AS FLOAT) AS amount, &#xD;&#xA;        TO_DATE(FROM_UNIXTIME(CAST(txn_date / 1000 AS  BIGINT))) AS txn_date, &#xD;&#xA;        merchant,&#xD;&#xA;&#x9;&#x9;status,&#xD;&#xA;        ingest_date &#xD;&#xA;    FROM  `&quot;+context.source_schema+&quot;`.`&quot;+context.target_table+&quot;` &#xD;&#xA;&#xD;&#xA;&#x9;UNION ALL&#xD;&#xA;&#xD;&#xA;&#x9;SELECT &#xD;&#xA;&#x9;&#x9;transaction_id,&#xD;&#xA;        account_id, &#xD;&#xA;        txn_type, &#xD;&#xA;        amount, &#xD;&#xA;        txn_date, &#xD;&#xA;        merchant, &#xD;&#xA;&#x9;&#x9;status,&#xD;&#xA;        ingest_date &#xD;&#xA;    FROM `&quot;+context.target_schema+&quot;`.`&quot;+context.target_table+ &quot;`&#xD;&#xA;)&#xD;&#xA;INSERT OVERWRITE TABLE `&quot;+context.target_schema+&quot;`.`&quot;+context.target_table+&quot;`  PARTITION (ingest_date='&quot;+(String) globalMap.get(&quot;ingest_date&quot;)+&quot;')&#xD;&#xA;&#x9;SELECT&#xD;&#xA;        transaction_id,&#xD;&#xA;        account_id, &#xD;&#xA;        txn_type, &#xD;&#xA;        amount, &#xD;&#xA;        txn_date, &#xD;&#xA;        merchant, &#xD;&#xA;&#x9;&#x9;status,&#xD;&#xA;&#x9;&#x9;'&quot; +(String) globalMap.get(&quot;source_system&quot;) + &quot;' AS `_source_system`,&#xD;&#xA;        FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_date_start`,&#xD;&#xA;        FROM_UNIXTIME(UNIX_TIMESTAMP('9999-12-31 23:59:59'),'yyyy-MM-dd HH:mm:ss') AS `_date_end`,&#xD;&#xA;&#x9;&#x9;FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_load_timestamp`&#xD;&#xA;&#x9;FROM&#xD;&#xA;        (SELECT&#xD;&#xA;&#x9;&#x9;&#x9;&quot; + context.select_columns + &quot;,&#xD;&#xA;&#x9;&#x9;&#x9;ROW_NUMBER() OVER (PARTITION BY &quot;+context.primary_key+&quot; ORDER BY &quot;+context.partition_column+&quot; DESC) rank&#xD;&#xA;         FROM source ) t1&#xD;&#xA;&#x9;WHERE t1.rank = 1&quot;"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
    <elementParameter field="CLOSED_LIST" name="TEZ_LIB" value="INSTALL" show="false"/>
