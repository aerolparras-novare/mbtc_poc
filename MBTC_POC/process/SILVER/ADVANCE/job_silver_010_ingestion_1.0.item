    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;INSERT INTO `&quot;+ context.target_schema +&quot;`.`&quot;+ context.tablename +&quot;` PARTITION (&quot;+context.partition_column+&quot;='&quot;+context.ingest_date+&quot;')&#xD;&#xA;&#x9;SELECT&#xD;&#xA;&#x9;&#x9;&quot; + globalMap.get(&quot;columns&quot;) + &quot;,&#xD;&#xA;        FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `date_start`,&#xD;&#xA;        FROM_UNIXTIME(UNIX_TIMESTAMP('9999-12-31 23:59:59'),'yyyy-MM-dd HH:mm:ss') AS `date_end`,&#xD;&#xA;        NULL AS `date_updated`,&#xD;&#xA;        '&quot;+context.proc_name+&quot;' AS `proc_name`,&#xD;&#xA;        '&quot;+context.proc_id+&quot;' AS `proc_id`,&#xD;&#xA;        '&quot;+context.src_tbl+&quot;' AS `proc_source`,&#xD;&#xA;        '&quot;+context.user+&quot;' AS `user`,&#xD;&#xA;        'N' AS `record_deleted`&#xD;&#xA;&#x9;FROM `&quot;+context.target_schema+&quot;`.`&quot;+context.tablename+&quot;` &#xD;&#xA;&quot;"/>
