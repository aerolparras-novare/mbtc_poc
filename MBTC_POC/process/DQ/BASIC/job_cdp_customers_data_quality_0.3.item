    <elementParameter field="TEXT" name="WASB_HOST" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="WASB_CONTAINER" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="WASB_USERNAME" value="&quot;&quot;" show="false"/>
    <elementParameter field="PASSWORD" name="WASB_PASSWORD" value="enc:system.encryption.key.v1:RPvqexj0Pfdi3pCiX48Lz6ph/gfLfxloJOODyRZx" show="false"/>
    <elementParameter field="TEXT" name="REMOTE_FOLDER" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_PROJECT_ID" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_CLUSTER_ID" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_REGION" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_JARS_BUCKET" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DEFINE_PATH_TO_GOOGLE_CREDENTIALS" value="false" show="false"/>
    <elementParameter field="FILE" name="PATH_TO_GOOGLE_CREDENTIALS" value="&quot;&quot;" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="context.dq_fact_table"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="LABEL" name="PARQUET_NOTE" value="Parquet is only supported if the distribution uses embedded Hive version 0.10 or later."/>
    <elementParameter field="CHECK" name="USE_PARQUET" value="false"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;INSERT INTO &quot;+context.dq_schema+&quot;.&quot;+context.dq_fact_table+&quot; PARTITION (execution_date='&quot; + (String)globalMap.get(&quot;ingest_date&quot;) + &quot;')&#xD;&#xA;SELECT &#xD;&#xA;     'Bronze' as layer &#xD;&#xA;    , 'customers' as table_name&#xD;&#xA;    , dq_category &#xD;&#xA;    , rule_name&#xD;&#xA;    , total_rows_scanned&#xD;&#xA;    , failed_rows_count&#xD;&#xA;    , CAST((1 - (failed_rows_count / NULLIF(total_rows_scanned,0))) * 100 AS DECIMAL(5,2)) as dq_score_pct&#xD;&#xA;    , 95.00 as threshold_amber&#xD;&#xA;    , 90.00 as threshold_red&#xD;&#xA;    , 'CDP' AS `_source_system`&#xD;&#xA;    , FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_date_start`&#xD;&#xA;    , FROM_UNIXTIME(UNIX_TIMESTAMP('9999-12-31 23:59:59'),'yyyy-MM-dd HH:mm:ss') AS `_date_end`&#xD;&#xA;    , FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_load_timestamp`&#xD;&#xA;FROM (&#xD;&#xA;    SELECT &#xD;&#xA;        COUNT(*) as total_rows_scanned&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN customer_id IS NULL OR TRIM(customer_id) = '' &#xD;&#xA;              OR join_date IS NULL OR TRIM(join_date) = '' &#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_mandatory_missing&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN UPPER(customer_id) IN ('NULL', 'N/A', 'NAN', 'UNDEFINED')&#xD;&#xA;              OR UPPER(first_name)  IN ('NULL', 'N/A', 'NAN', 'UNDEFINED') &#xD;&#xA;              OR UPPER(last_name)   IN ('NULL', 'N/A', 'NAN', 'UNDEFINED') &#xD;&#xA;              OR UPPER(email)       IN ('NULL', 'N/A', 'NAN', 'UNDEFINED') &#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_null_literals&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN first_name RLIKE '([^ -~]|\\\\uFFFD)' &#xD;&#xA;              OR last_name  RLIKE '([^ -~]|\\\\uFFFD)'&#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_char_encoding&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN customer_id LIKE '%,%' OR customer_id LIKE '%|%'&#xD;&#xA;              OR first_name  LIKE '%,%' OR first_name  LIKE '%|%'&#xD;&#xA;              OR last_name   LIKE '%,%' OR last_name   LIKE '%|%'&#xD;&#xA;              OR email       LIKE '%,%' OR email       LIKE '%|%'&#xD;&#xA;              OR join_date   LIKE '%,%' OR join_date   LIKE '%|%'&#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_rogue_delimiters&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN first_name RLIKE '^\\\\s+.*' OR first_name RLIKE '.*\\\\s+$'&#xD;&#xA;              OR last_name  RLIKE '^\\\\s+.*' OR last_name  RLIKE '.*\\\\s+$'&#xD;&#xA;              OR email      RLIKE '^\\\\s+.*' OR email      RLIKE '.*\\\\s+$'&#xD;&#xA;              OR customer_id RLIKE '^\\\\s+.*' OR customer_id RLIKE '.*\\\\s+$'&#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_trim_whitespace&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN customer_id LIKE '\&quot;%' OR customer_id LIKE '%\&quot;'&#xD;&#xA;              OR first_name  LIKE '\&quot;%' OR first_name  LIKE '%\&quot;' &#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_residual_quotes&#xD;&#xA;        , SUM(CASE &#xD;&#xA;            WHEN LENGTH(customer_id) > 10 &#xD;&#xA;            THEN 1 ELSE 0 &#xD;&#xA;        END) as fail_col_length_drift&#xD;&#xA;    FROM bronze.customers&#xD;&#xA;) BaseStats&#xD;&#xA;LATERAL VIEW STACK(7&#xD;&#xA;    , 'Completeness', 'Missing_Mandatory_Fields',      fail_mandatory_missing&#xD;&#xA;    , 'Completeness', 'Check_Null_String_Literals',    fail_null_literals&#xD;&#xA;    , 'Validity',     'Found_Unprintable_Chars',       fail_char_encoding&#xD;&#xA;    , 'Validity',   'Found_Rogue_Delimiters',        fail_rogue_delimiters&#xD;&#xA;    , 'Consistency',   'Found_Untrimmed_Whitespace',    fail_trim_whitespace&#xD;&#xA;    , 'Integrity',    'Found_Residual_Quotes',         fail_residual_quotes&#xD;&#xA;    , 'Integrity',    'Column_Length_Exceeded',        fail_col_length_drift&#xD;&#xA;) Exploded AS dq_category, rule_name, failed_rows_count&#xD;&#xA;&quot;"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
