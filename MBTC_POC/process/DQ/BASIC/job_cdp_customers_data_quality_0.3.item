    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;CREATE TABLE IF NOT EXISTS &quot;+context.dq_schema+&quot;.&quot;+context.dq_fact_table+&quot; (&#xD;&#xA;    -- Business Keys &#xD;&#xA;      layer STRING COMMENT 'Bronze, Silver, Gold'&#xD;&#xA;    , table_name STRING COMMENT 'Table being profiled'&#xD;&#xA;    , dq_category STRING COMMENT 'DQ Dimension'&#xD;&#xA;    , rule_name STRING COMMENT 'Name of the rule applied'&#xD;&#xA;    -- Metrics&#xD;&#xA;    , total_rows_scanned BIGINT COMMENT 'Denominator'&#xD;&#xA;    , failed_rows_count BIGINT COMMENT 'Numerator'&#xD;&#xA;    , dq_score_pct DECIMAL(5,2) COMMENT 'Score'&#xD;&#xA;    , threshold_amber DECIMAL(5,2) COMMENT 'Warning threshold'&#xD;&#xA;    , threshold_red DECIMAL(5,2) COMMENT 'Failure threshold'&#xD;&#xA;    -- Control Columns&#xD;&#xA;    , `_source_system` VARCHAR(150) COMMENT 'Origin system'&#xD;&#xA;    , `_date_start` TIMESTAMP COMMENT 'Batch processing start time'&#xD;&#xA;    , `_date_end` TIMESTAMP COMMENT 'Batch processing end time'&#xD;&#xA;    , `_load_timestamp` TIMESTAMP COMMENT 'When this log entry was inserted'&#xD;&#xA;)&#xD;&#xA;COMMENT 'Aggregated Data Quality scores for Dashboarding'&#xD;&#xA;PARTITIONED BY (execution_date STRING)&#xD;&#xA;-- CRITICAL CHANGE 1: Must be ORC&#xD;&#xA;STORED AS ORC&#xD;&#xA;-- CRITICAL CHANGE 2: Enable ACID transactions&#xD;&#xA;TBLPROPERTIES ('transactional'='true')&#xD;&#xA;&quot;"/>
