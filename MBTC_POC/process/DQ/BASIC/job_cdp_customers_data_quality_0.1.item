    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;CREATE TABLE IF NOT EXISTS dq.dq_exception_log (&#xD;&#xA;    -- Business Keys&#xD;&#xA;      layer STRING COMMENT 'Data layer (Bronze, Silver, Gold)'&#xD;&#xA;    , table_name STRING COMMENT 'Source table that failed validation'&#xD;&#xA;    , dq_category STRING COMMENT 'Validity, Accuracy, Consistency, Completeness, Integrity'&#xD;&#xA;    -- Error Details&#xD;&#xA;    , error_code STRING COMMENT 'Specific error slug (e.g., INVALID_EMAIL_FORMAT)'&#xD;&#xA;    , error_message STRING COMMENT 'Human readable error description'&#xD;&#xA;    , record_key STRING COMMENT 'Primary key of the failing record (e.g., customer_id)'&#xD;&#xA;    , raw_record STRING COMMENT 'Pipe-delimited full row content for debugging'&#xD;&#xA;    -- Control Columns&#xD;&#xA;    , `_source_system` VARCHAR(150) COMMENT 'Origin system'&#xD;&#xA;    , `_date_start` TIMESTAMP COMMENT 'Batch processing start time'&#xD;&#xA;    , `_date_end` TIMESTAMP COMMENT 'Batch processing end time'&#xD;&#xA;    , `_load_timestamp` TIMESTAMP COMMENT 'When this log entry was inserted'&#xD;&#xA;)&#xD;&#xA;COMMENT 'Log table for individual records that failed Data Quality business rules'&#xD;&#xA;PARTITIONED BY (execution_date STRING)&#xD;&#xA;-- CRITICAL CHANGE 1: Must be ORC for Hive ACID&#xD;&#xA;STORED AS ORC&#xD;&#xA;-- CRITICAL CHANGE 2: Enable ACID transactions&#xD;&#xA;TBLPROPERTIES ('transactional'='true')&#xD;&#xA;&quot;"/>
