    <elementParameter field="PASSWORD" name="WASB_PASSWORD" value="enc:system.encryption.key.v1:sjyIUsny/eQczWE2WVPCpxaTzLt3daaTQLCwv+iN" show="false"/>
    <elementParameter field="TEXT" name="REMOTE_FOLDER" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_PROJECT_ID" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_CLUSTER_ID" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_REGION" value="&quot;&quot;" show="false"/>
    <elementParameter field="TEXT" name="GOOGLE_JARS_BUCKET" value="&quot;&quot;" show="false"/>
    <elementParameter field="CHECK" name="DEFINE_PATH_TO_GOOGLE_CREDENTIALS" value="false" show="false"/>
    <elementParameter field="FILE" name="PATH_TO_GOOGLE_CREDENTIALS" value="&quot;&quot;" show="false"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;dq_dashboard_fact&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" value="" show="false"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="LABEL" name="PARQUET_NOTE" value="Parquet is only supported if the distribution uses embedded Hive version 0.10 or later."/>
    <elementParameter field="CHECK" name="USE_PARQUET" value="false"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;WITH &#xD;&#xA;-- =========================================================================&#xD;&#xA;-- STEP 1: CALCULATE FLAGS &amp; TOTALS (Single Pass Scan)&#xD;&#xA;-- =========================================================================&#xD;&#xA;Calculated_Flags AS (&#xD;&#xA;    SELECT &#xD;&#xA;        -- 1. Accuracy: Tenure cannot be negative&#xD;&#xA;        CASE WHEN TENURE_DAYS &lt; 0 THEN 1 ELSE 0 END as err_neg_tenure&#xD;&#xA;        -- 2. Validity: Aggregate Balance Math Check&#xD;&#xA;        , CASE WHEN ABS(TOTAL_BALANCE - (SAVINGS_BALANCE + CHECKING_BALANCE + CREDIT_CARD_EXPOSURE)) > 0.01 &#xD;&#xA;               THEN 1 ELSE 0 END as err_bal_math&#xD;&#xA;        -- 3. Accuracy: Active Customer Logic&#xD;&#xA;        , CASE WHEN CUSTOMER_LIFECYCLE_STATUS = 'Active' &#xD;&#xA;                AND (LAST_TXN_DATE &lt; DATE_SUB(current_date(), 30) OR LAST_TXN_DATE IS NULL) &#xD;&#xA;               THEN 1 ELSE 0 END as err_active_logic&#xD;&#xA;        -- 4. Integrity: Ghost Balance&#xD;&#xA;        , CASE WHEN TOTAL_ACCOUNTS = 0 AND TOTAL_BALANCE > 0 &#xD;&#xA;               THEN 1 ELSE 0 END as err_ghost_bal&#xD;&#xA;        -- 5. Completeness: Transaction History Integrity&#xD;&#xA;        , CASE WHEN LIFETIME_TXN_COUNT > 0 AND LAST_TXN_DATE IS NULL &#xD;&#xA;               THEN 1 ELSE 0 END as err_missing_txn_date&#xD;&#xA;        -- 6. Accuracy: KYC Compliance for Active Users&#xD;&#xA;        , CASE WHEN CUSTOMER_LIFECYCLE_STATUS = 'Active' AND KYC_STATUS != 'Verified' &#xD;&#xA;               THEN 1 ELSE 0 END as err_kyc_mismatch&#xD;&#xA;        -- 7. Validity: Negative Liability&#xD;&#xA;        , CASE WHEN SAVINGS_BALANCE &lt; 0 OR CHECKING_BALANCE &lt; 0 &#xD;&#xA;               THEN 1 ELSE 0 END as err_neg_liability&#xD;&#xA;        -- 8. Consistency: Ghost Transactions&#xD;&#xA;        , CASE WHEN (TOTAL_DEPOSITS > 0 OR TOTAL_WITHDRAWALS > 0) AND LIFETIME_TXN_COUNT = 0 &#xD;&#xA;               THEN 1 ELSE 0 END as err_ghost_txns&#xD;&#xA;        -- Helper for denominator&#xD;&#xA;        , 1 as row_counter&#xD;&#xA;    FROM gold.customer_360&#xD;&#xA;    -- Optional: WHERE execution_date = '19000101'&#xD;&#xA;),&#xD;&#xA;-- =========================================================================&#xD;&#xA;-- STEP 2: EXPLODE &amp; AGGREGATE (Turn Columns into Dashboard Rows)&#xD;&#xA;-- =========================================================================&#xD;&#xA;Aggregated_Stats AS (&#xD;&#xA;    SELECT &#xD;&#xA;        dq_category,&#xD;&#xA;        rule_name,&#xD;&#xA;        SUM(is_failed) as failed_rows,&#xD;&#xA;        SUM(row_counter) as total_rows&#xD;&#xA;    FROM Calculated_Flags&#xD;&#xA;    -- Pivot the 8 columns into Rows&#xD;&#xA;    LATERAL VIEW STACK(8&#xD;&#xA;        , 'Accuracy',     'NEGATIVE_TENURE',       err_neg_tenure&#xD;&#xA;        , 'Validity',     'BALANCE_MATH_MISMATCH', err_bal_math&#xD;&#xA;        , 'Accuracy',     'LOGIC_ACTIVE_MISMATCH', err_active_logic&#xD;&#xA;        , 'Integrity',    'GHOST_BALANCE',         err_ghost_bal&#xD;&#xA;        , 'Completeness', 'MISSING_TXN_DATE',      err_missing_txn_date&#xD;&#xA;        , 'Accuracy',     'KYC_ACTIVE_MISMATCH',   err_kyc_mismatch&#xD;&#xA;        , 'Validity',     'NEGATIVE_LIABILITY',    err_neg_liability&#xD;&#xA;        , 'Consistency',  'GHOST_TRANSACTIONS',    err_ghost_txns&#xD;&#xA;    ) exploded_table AS dq_category, rule_name, is_failed&#xD;&#xA;    GROUP BY dq_category, rule_name&#xD;&#xA;)&#xD;&#xA;-- =========================================================================&#xD;&#xA;-- STEP 3: INSERT TO DASHBOARD FACT&#xD;&#xA;-- =========================================================================&#xD;&#xA;INSERT INTO dq.dq_dashboard_fact PARTITION (execution_date='&quot;+(String) globalMap.get(&quot;ingest_date&quot;)+&quot;')&#xD;&#xA;SELECT &#xD;&#xA;&#x9; 'Gold' as layer&#xD;&#xA;    , 'customer_360' as table_name&#xD;&#xA;    , dq_category&#xD;&#xA;    , rule_name&#xD;&#xA;    , total_rows as total_rows_scanned&#xD;&#xA;    , failed_rows as failed_rows_count&#xD;&#xA;    -- Score Calculation: (1 - (Fail/Total)) * 100&#xD;&#xA;    , CAST((1 - (failed_rows / NULLIF(total_rows, 0))) * 100 AS DECIMAL(5,2)) as dq_score_pct&#xD;&#xA;    , 100.00 as threshold_amber -- Gold requires strict targets&#xD;&#xA;    , 98.00  as threshold_red&#xD;&#xA;     , 'CDP' AS `_source_system`&#xD;&#xA;&#x9;, FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_date_start`&#xD;&#xA;&#x9;, FROM_UNIXTIME(UNIX_TIMESTAMP('9999-12-31 23:59:59'),'yyyy-MM-dd HH:mm:ss') AS `_date_end`&#xD;&#xA;&#x9;, FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_load_timestamp`&#xD;&#xA;FROM Aggregated_Stats&#xD;&#xA;&quot;"/>
    <elementParameter field="CHECK" name="DIE_ON_ERROR" value="true"/>
    <elementParameter field="CLOSED_LIST" name="TEZ_LIB" value="INSTALL" show="false"/>
    <elementParameter field="DIRECTORY_HADOOP" name="TEZ_LIB_FOLDER" value="&quot;/tmp/{USERNAME}/talend_tez_libs/{custom|HIVE_VERSION}&quot;" show="false"/>
    <elementParameter field="TEXT" name="GROUP" value="&quot;supergroup&quot;" show="false"/>
    <elementParameter field="BOTH_HADOOP" name="TEZ_LIB_PATH" value="&quot;&quot;" show="false"/>
