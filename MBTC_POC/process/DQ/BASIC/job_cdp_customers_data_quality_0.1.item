    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;&#xD;&#xA;WITH &#xD;&#xA;failed_counts AS (&#xD;&#xA;    SELECT &#xD;&#xA;        dq_category&#xD;&#xA;        , error_code&#xD;&#xA;        , COUNT(*) as failed_rows&#xD;&#xA;    FROM dq.dq_exception_log&#xD;&#xA;    WHERE table_name = 'customers'&#xD;&#xA;    GROUP BY dq_category, error_code&#xD;&#xA;),&#xD;&#xA;total_count AS (&#xD;&#xA;    SELECT COUNT(*) as total &#xD;&#xA;    FROM bronze.customers&#xD;&#xA;)&#xD;&#xA;INSERT INTO dq.dq_dashboard_fact PARTITION (execution_date='&quot;+(String) globalMap.get(&quot;ingest_date&quot;)+&quot;')&#xD;&#xA;SELECT &#xD;&#xA;&#x9; 'Silver' as layer&#xD;&#xA;    , 'customers' as table_name&#xD;&#xA;    , f.dq_category&#xD;&#xA;    , f.error_code&#xD;&#xA;    , t.total as total_records&#xD;&#xA;    , f.failed_rows&#xD;&#xA;    , CAST((1 - (f.failed_rows / NULLIF(t.total, 0))) * 100 AS DECIMAL(5,2)) as actual_score&#xD;&#xA;    , 99.00 as target_score&#xD;&#xA;    , 95.00 as threshold_score&#xD;&#xA;    , 'CDP' AS `_source_system`&#xD;&#xA;&#x9;, FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_date_start`&#xD;&#xA;&#x9;, FROM_UNIXTIME(UNIX_TIMESTAMP('9999-12-31 23:59:59'),'yyyy-MM-dd HH:mm:ss') AS `_date_end`&#xD;&#xA;&#x9;, FROM_UNIXTIME(UNIX_TIMESTAMP(),'yyyy-MM-dd HH:mm:ss') AS `_load_timestamp`&#xD;&#xA;FROM failed_counts f&#xD;&#xA;CROSS JOIN total_count t&#xD;&#xA;&quot;"/>
