  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="480" posY="160" sizeX="120" sizeY="40">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_START" value="// start part of your Java code&#xA;// Initialize the loop tracker"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_MAIN" value="// here is the main part of the component,&#xA;// a piece of code executed in the row&#xA;// loop&#xA;String content = row2.content.toString();&#xA;&#xA;// Regex to find each {object}&#xA;java.util.regex.Pattern objPattern = java.util.regex.Pattern.compile(&quot;\\{[^\\}]+\\}&quot;);&#xA;java.util.regex.Matcher objMatcher = objPattern.matcher(content);&#xA;&#xA;while (objMatcher.find()) {&#xA;    String jsonObject = objMatcher.group();&#xA;    java.util.Map&lt;String, String> currentData = new java.util.LinkedHashMap&lt;String, String>();&#xA;    &#xA;    // Extract KV pairs&#xA;    java.util.regex.Pattern kvPattern = java.util.regex.Pattern.compile(&quot;\&quot;([^\&quot;]+)\&quot;\\s*:\\s*(\&quot;?[^\&quot;,}]*\&quot;?)&quot;);&#xA;    java.util.regex.Matcher kvMatcher = kvPattern.matcher(jsonObject);&#xA;&#xA;    while (kvMatcher.find()) {&#xA;        currentData.put(kvMatcher.group(1), kvMatcher.group(2).replace(&quot;\&quot;&quot;, &quot;&quot;).trim());&#xA;    }&#xA;&#xA;    // Set Header on first row of first object&#xA;    if (globalMap.get(&quot;masterHeader&quot;) == null) {&#xA;        java.util.List&lt;String> master = new java.util.ArrayList&lt;String>(currentData.keySet());&#xA;        globalMap.put(&quot;masterHeader&quot;, master);&#xA;        globalMap.put(&quot;headerString&quot;, String.join(&quot;,&quot;, master));&#xA;    }&#xA;&#xA;    // Align values&#xA;    java.util.List&lt;String> master = (java.util.List&lt;String>) globalMap.get(&quot;masterHeader&quot;);&#xA;    StringBuilder csvRow = new StringBuilder();&#xA;    for (int i = 0; i &lt; master.size(); i++) {&#xA;        String val = currentData.get(master.get(i));&#xA;        csvRow.append(val == null ? &quot;&quot; : val);&#xA;        if (i &lt; master.size() - 1) csvRow.append(&quot;,&quot;);&#xA;    }&#xA;&#xA;    // THIS IS THE KEY: Set the output and emit the row&#xA;    row4.csv_line = csvRow.toString();&#xA;    &#xA;    // Manually trigger the data flow for this iteration&#xA;    // (This ensures tFileOutputDelimited gets called for EVERY object found)"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE_END" value="} // This closes the while(objMatcher.find()) loop from the Main Code"/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="arrayData"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaFlex_1">
      <column comment="" key="false" length="-1" name="csv_line" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
    </metadata>
  </node>
