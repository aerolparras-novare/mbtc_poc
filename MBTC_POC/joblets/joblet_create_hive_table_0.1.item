    <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="440" posY="280" sizeX="120" sizeY="40">
      <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2" show="false"/>
      <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String controlColumns = &quot;&quot;;&#xD;&#xA;String parquetLocation = &quot;&quot;;&#xD;&#xA;&#xD;&#xA;String target_schema = context.target_schema.toLowerCase();&#xD;&#xA;&#xD;&#xA;if (target_schema.contains(&quot;bronze&quot;)) {&#xD;&#xA;&#x9;parquetLocation = context.dir_hdfs_bronze + context.tablename + &quot;/&quot;;&#xD;&#xA;&#xD;&#xA;} else if (target_schema.contains(&quot;silver&quot;)) {&#xD;&#xA;    parquetLocation = context.dir_hdfs_silver + context.tablename + &quot;/&quot;;&#xD;&#xA;    controlColumns = &quot;, `_ingest_ts` TIMESTAMP, `_source_system` VARCHAR(150), `_load_timestamp` TIMESTAMP&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;globalMap.put(&quot;controlColumns&quot;, controlColumns);&#xD;&#xA;globalMap.put(&quot;parquetLocation&quot;, parquetLocation);&#xD;&#xA;&#xD;&#xA;System.setProperty(&quot;mapred.job.name&quot;, &quot;&quot;);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;Paruqet Location: &quot;+ globalMap.put(&quot;parquetLocation&quot;, parquetLocation));&#xD;&#xA;System.out.println(&quot;DIR_HDFS_BRONZE: &quot; +context.dir_hdfs_bronze);&#xD;&#xA;&#xD;&#xA;"/>
      <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
      <elementParameter field="TEXT" name="LABEL" value="setControlColumns"/>
      <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
      <metadata connector="FLOW" name="tJava_2"/>
    </node>
